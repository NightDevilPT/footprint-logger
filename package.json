{
	"name": "@footprint/logger",
	"version": "1.0.0",
	"description": "Universal logging for JavaScript/TypeScript - works across React, Next.js, Express, and NestJS",
	"author": "NightDevilPT",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/NightDevilPT/footprint-logger"
	},
	"keywords": [
		"logger",
		"logging",
		"footprint",
		"universal-logger",
		"react",
		"nextjs",
		"express",
		"nestjs",
		"typescript",
		"fullstack",
		"file-logging",
		"log-rotation",
		"log-formatter",
		"color-logs"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./react": {
			"import": "./dist/react/index.js",
			"require": "./dist/react/index.js",
			"types": "./dist/react/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.17",
		"chalk": "^5.6.2",
		"date-fns": "^4.1.0",
		"express": "^5.2.1",
		"next": "^16.2.1",
		"react": "^19.2.4",
		"safe-stable-stringify": "^2.5.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"eslint": "^10.1.0",
		"jest": "^30.3.0",
		"rimraf": "^6.0.1",
		"ts-jest": "^29.4.6",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}